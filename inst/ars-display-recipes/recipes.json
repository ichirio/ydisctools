          "dataset": "ADSL",
          "variable": "USUBJID"
        },
        {
          "name": "Subjects with at least one TEAE, n (%)",
          "method": "categorical_summary",
          "dataset": "ADAE",
          "variable": "USUBJID",
          "where": "TRTEMFL EQ Y",
          "denominator": "auto"
        },
        {
          "name": "TEAE by System Organ Class, n (%)",
          "method": "categorical_summary",
          "dataset": "ADAE",
          "variable": "USUBJID",
          "group2": "ADAE.AEBODSYS",
          "where": "TRTEMFL EQ Y",
          "denominator": "auto"
        }
      ],
      "section_key": "safety_ae"
    },
    {
      "id": "ae_pt",
      "title_default": "Summary of Treatment-Emergent Adverse Events by Preferred Term",
      "source": "FDA ST&F Integrated Guide (fda-ae-t13, flat PT level); PHUSE Analyses & Displays: Adverse Events",
      "stub_label": "Preferred Term",
      "analyses": [
        {
