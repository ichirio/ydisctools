        },
        {
          "name": "TEAE by severity, n (%)",
          "method": "categorical_summary",
          "dataset": "ADAE",
          "variable": "USUBJID",
          "group2": "ADAE.AESEV",
          "where": "TRTEMFL EQ Y",
          "denominator": "auto"
        }
