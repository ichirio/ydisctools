          "method": "categorical_summary",
          "dataset": "ADAE",
          "variable": "USUBJID",
          "where": "TRTEMFL EQ Y",
          "denominator": "auto"
        },
        {
          "name": "TEAE by Preferred Term, n (%)",
          "method": "categorical_summary",
          "dataset": "ADAE",
          "variable": "USUBJID",
          "group2": "ADAE.AEDECOD",
          "where": "TRTEMFL EQ Y",
          "denominator": "auto"
        }
      ],
      "section_key": "safety_ae"
    },
    {
      "id": "ae_severity",
      "title_default": "Summary of Treatment-Emergent Adverse Events by Maximum Severity",
      "source": "PHUSE Analyses & Displays: Adverse Events (severity summary)",
      "stub_label": "Severity",
      "analyses": [
        {
          "name": "Number of subjects",
